# ─── NXTLI GEO Scan — environment variables ───────────────────────────────
# Copy to .env.local for local dev. Set the same vars in your Vercel project.
# Everything here is server-side only EXCEPT the NEXT_PUBLIC_* vars.

# ── Supabase (lead + scan storage) ────────────────────────────────────────
# Without these the scan still works end-to-end, but nothing is persisted.
# The Vercel↔Supabase integration sets these automatically in your Vercel
# project (SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, POSTGRES_URL*, …).
SUPABASE_URL=
# Service-role key — SERVER ONLY. Never expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: public URL/anon key, only if you add client-side reads later.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# One-shot schema migration via /api/geo/migrate (runs the DB schema using the
# Postgres connection the Vercel↔Supabase integration injects). Set to any
# random string to ENABLE the route; unset it again afterwards to DISABLE it.
MIGRATE_SECRET=
# The route auto-detects the connection string from these (set by Vercel):
# POSTGRES_URL / POSTGRES_PRISMA_URL / DATABASE_URL / SUPABASE_DB_URL / POSTGRES_URL_NON_POOLING

# Config diagnostics via /api/geo/diag (reports provider, key presence, and
# whether the geo-page-checker skill is found). Set to enable; unset to disable.
GEO_DIAG_SECRET=

# ── AI analysis engine ────────────────────────────────────────────────────
# Provider selection. Leave unset to auto-pick: geo-skill → claude → mock.
#   geo-skill | claude | mock
# GEO_ANALYSIS_PROVIDER=

# Required for both geo-skill and claude providers. SERVER ONLY.
# Must belong to the Anthropic org/workspace that owns the shared skill.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-8)
# GEO_ANALYSIS_MODEL=claude-opus-4-8

# Shared NXTLI org Claude skill (the "geo-skill" provider, default primary).
# The skill is resolved by name; override the id to skip the lookup.
# GEO_SKILL_NAME=geo-page-checker
# GEO_SKILL_ID=
# GEO_SKILL_VERSION=latest

# ── Email (report delivery) ───────────────────────────────────────────────
# Default adapter is Resend (https://resend.com). Without these the report is
# prepared but not sent. SERVER ONLY.
RESEND_API_KEY=
GEO_EMAIL_FROM="NXTLI <brian@geo.nxtli.com>"

# ── PDF (optional) ────────────────────────────────────────────────────────
# none (default) serves an HTML report. See lib/geo/report/pdf.ts to wire a
# real generator (playwright | service).
# GEO_PDF_STRATEGY=none

# ── CTA links (safe to expose) ────────────────────────────────────────────
# Where the "Plan een GEO-strategiesessie" buttons point.
NEXT_PUBLIC_GEO_STRATEGY_CALL_URL=https://nxtli.com
# Used in the report email's "plan a session" link (server-side).
GEO_STRATEGY_CALL_URL=https://nxtli.com
